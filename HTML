    <p>
      Bachelor of Science in Computer Science<br>
      Faculty of Science, Tanta University
    </p>
  </div>
</section>

<section>
  <h2>Skills</h2>
  <div class="skills">
    <div class="skill">Python</div>
    <div class="skill">Data Analysis</div>
    <div class="skill">Machine Learning</div>
    <div class="skill">SQL</div>
